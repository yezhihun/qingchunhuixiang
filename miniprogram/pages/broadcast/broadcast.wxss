/* pages/broadcast/broadcast.wxss */
.broadcast-container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

.sunset-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: url('/assets/backgrounds/sunset.jpg') center/cover no-repeat;
  opacity: 0.7;
}

.broadcast-panel {
  position: relative;
  z-index: 10;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  margin: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}

.broadcast-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #eee;
}

.broadcast-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.broadcast-time {
  font-size: 28rpx;
  color: #666;
}

.current-program {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 15rpx;
}

.program-icon image {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
}

.program-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.program-description {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.program-timer {
  margin-top: 15rpx;
  font-size: 24rpx;
  color: #e74c3c;
}

.student-activities {
  margin-bottom: 30rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.activity-avatar image {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.activity-content {
  flex: 1;
}

.activity-student {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.activity-action {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.activity-location {
  font-size: 24rpx;
  color: #999;
}

.activity-mood {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-left: 20rpx;
}

.activity-mood.happy { background-color: #27ae60; }
.activity-mood.sad { background-color: #2980b9; }
.activity-mood.excited { background-color: #e74c3c; }
.activity-mood.tired { background-color: #f39c12; }
.activity-mood.neutral { background-color: #95a5a6; }

.classic-scenes {
  margin-bottom: 30rpx;
}

.scene-item {
  text-align: center;
}

.scene-item image {
  width: 100%;
  border-radius: 15rpx;
  margin-bottom: 15rpx;
}

.scene-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.scene-description {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.share-section {
  text-align: center;
}

.share-button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 10rpx 20rpx rgba(102, 126, 234, 0.3);
}

.share-button:active {
  transform: scale(0.95);
}