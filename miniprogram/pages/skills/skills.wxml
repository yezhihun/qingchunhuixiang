<!-- pages/skills/skills.wxml -->
<view class="container">
  <view class="header">
    <text class="title">技能系统</text>
  </view>
  
  <view class="skills-list">
    <view class="skill-item" wx:for="{{skills}}" wx:key="id">
      <view class="skill-info">
        <text class="skill-name">{{item.name}}</text>
        <text class="skill-level">Lv.{{item.level}}</text>
      </view>
      <progress 
        class="skill-progress" 
        percent="{{item.progress}}" 
        stroke-width="4" 
        active-color="#4299e1"
        background-color="#edf2f7">
      </progress>
      <text class="skill-desc">{{item.description}}</text>
    </view>
  </view>
  
  <view class="actions">
    <button class="action-btn" bindtap="upgradeSkill">升级技能</button>
    <button class="action-btn secondary" bindtap="learnNewSkill">学习新技能</button>
  </view>
</view>