/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  background-color: #f7fafc;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  margin: 20rpx auto;
  display: block;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2d3748;
  display: block;
  margin: 10rpx 0;
}

.subtitle {
  font-size: 24rpx;
  color: #718096;
  display: block;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.username {
  font-size: 28rpx;
  color: #2d3748;
}

.schools-list {
  margin-top: 20rpx;
}

.school-item {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.school-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 10rpx;
}

.school-stats {
  display: flex;
  justify-content: space-between;
  color: #718096;
  font-size: 24rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #718096;
}